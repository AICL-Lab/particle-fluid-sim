{
  "name": "webgpu-particle-fluid-sim",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "High-performance WebGPU particle fluid simulation with compute shaders",
  "author": "",
  "license": "MIT",
  "keywords": [
    "webgpu",
    "particle",
    "simulation",
    "compute-shader",
    "wgsl",
    "typescript"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,css}\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite",
    "prepare": "npm run typecheck"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "@webgpu/types": "^0.1.40",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "fast-check": "^3.23.1",
    "happy-dom": "^20.9.0",
    "prettier": "^3.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.0.1",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
